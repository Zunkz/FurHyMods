Ingredient_Bar_Adamantite.name = Adamantite Ingot
Ingredient_Bar_Adamantite.description = <i>This rare metal was once instrumental to the advancements made by the peoples of Crucible. Though little remains of the city's former splendor, traces of the resilient ore can still be found in the depths beneath those scorched lands.</i>
Ingredient_Bar_Bronze.name = Bronze Ingot
Ingredient_Bar_Cobalt.name = Cobalt Ingot
Ingredient_Bar_Cobalt.description = <i>In Outlander myth, this metal is said to be cold to the touch, even when molten. While verifying this would be ill-advised, its origins amidst the frigid peaks and frozen caverns of their territory lend the story some credence.</i>
Ingredient_Bar_Copper.name = Copper Ingot
Ingredient_Bar_Copper.description = A common metal smelted from ore found throughout all regions of Orbis.
Ingredient_Bar_Gold.name = Gold Ingot
Ingredient_Bar_Iron.name = Iron Ingot
Ingredient_Bar_Iron.description = Its natural abundance and reliable strength make this the ideal candidate for fashioning common tools and weapons.
Ingredient_Bar_Mithril.name = Mithril Ingot
Ingredient_Bar_Onyxium.name = Onyxium Ingot
Ingredient_Bar_Prisma.name = Prisma Ingot
Ingredient_Bar_Silver.name = Silver Ingot
Ingredient_Bar_Thorium.name = Thorium Ingot
Ingredient_Bar_Thorium.description = <i>While Ferans do not themselves make use of this metal, they keep a vigilant watch over its deposits in the sun-scorched deserts and arid badlands. Should their age-old enemies rise once more, these reserves would be the first they sought to harvest.</i>
Ingredient_Bolt_Cindercloth.name = Bolt of Cindercloth
